  "scripts": {
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.webview.json",
    "lint": "eslint .",
    "test": "npm run typecheck && npm run lint && npm run test:unit",
    "test:unit": "node -e \"require('fs').rmSync('out-test',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node scripts/run-unit-tests.mjs",
    "build": "node esbuild.config.mjs",
    "build:prod": "node esbuild.config.mjs --production",
    "compile": "npm run typecheck && npm run build",
    "watch": "node esbuild.config.mjs --watch",
