# Peridot local state (per-machine hooks/skills/config/sessions/memory).
# Default hooks and skill templates that should ship with the binary are
# tracked under `templates/peridot-init/` instead — the agent copies them
# into a user's `.peridot/` on first run.
.peridot/

# Rust build output
target/

# Local editor/system files
.DS_Store
*.swp
*.swo

# User-local Claude Code settings (per-machine, not part of the project)
.claude/
